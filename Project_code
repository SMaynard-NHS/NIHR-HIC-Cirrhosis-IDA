# SNOMED codes to include (numeric)
snomed_tx_keep <- c(
  18027006, 27280000, 28009009, 33167004, 737297006, 174425003, 174426002,
  174427006, 213153001, 235910007, 235911006, 235912004, 316061004, 426356008,
